# ============================================================================
# ПриДел — Конфигурация окружения
# ============================================================================

# ─── MAX Bot ────────────────────────────────────────────────────────────────
MAX_BOT_TOKEN=
MAX_API_BASE_URL=https://platform-api.max.ru
MAX_POLLING_TIMEOUT_SEC=30
MAX_DELIVERY_MODE=auto
MAX_WEBHOOK_URL=
MAX_WEBHOOK_PATH=/api/max/webhook
MAX_WEBHOOK_SECRET=
WEBAPP_URL=https://4-2.xn--p1ai/app

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://masterbot:masterbot@db:5432/masterbot
DATABASE_URL_SYNC=postgresql://masterbot:masterbot@db:5432/masterbot
POSTGRES_USER=masterbot
POSTGRES_PASSWORD=masterbot
POSTGRES_DB=masterbot

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# ─── Приложение ─────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=change-this-to-random-secret-key
WEBAPP_SESSION_TTL_SEC=86400
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── Платформа ──────────────────────────────────────────────────────────────
PLATFORM_OPERATOR_NAME=4-2
PLATFORM_NAME=ПриДел
PLATFORM_PUBLIC_DOMAIN=4-2.рф
PLATFORM_PUBLIC_DOMAIN_ASCII=4-2.xn--p1ai
PLATFORM_FEE_PCT=20.0
SENIOR_MASTER_SHARE_PCT=5.0
ADMIN_SHARE_PCT=5.0
DEFAULT_CURRENCY=RUB
DEFAULT_CITY=Стерлитамак
DEFAULT_REGION=Башкортостан

# ─── AI ─────────────────────────────────────────────────────────────────────
AI_PROVIDER=disabled
AI_API_KEY=
AI_API_URL=
AI_MODEL=
AI_TIMEOUT_SEC=30

# ─── Оплата ─────────────────────────────────────────────────────────────────
PAYMENT_PHONE=+79001234567
PAYMENT_BANK_NAME=Сбербанк
PAYMENT_RECIPIENT_NAME=ИП Иванов

# ─── Логирование ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── Администраторы ─────────────────────────────────────────────────────────
# Переменные названы исторически, но хранят внешние ID пользователей мессенджера.
# Для MAX сюда нужно подставлять `user_id` пользователя из MAX.
OWNER_TELEGRAM_ID=0
ADMIN_TELEGRAM_IDS=
