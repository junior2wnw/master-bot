# ============================================================================
# МастерБот — Конфигурация окружения
# ============================================================================
# Скопируйте: cp .env.example .env и заполните значения
# Или используйте: sudo bash deploy/setup.sh (сгенерирует автоматически)
# ============================================================================

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Получите у @BotFather: https://t.me/BotFather
BOT_TOKEN=your_telegram_bot_token_here

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://masterbot:masterbot@db:5432/masterbot
DATABASE_URL_SYNC=postgresql://masterbot:masterbot@db:5432/masterbot
POSTGRES_USER=masterbot
POSTGRES_PASSWORD=masterbot
POSTGRES_DB=masterbot

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# ─── Приложение ──────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=change-this-to-random-secret-key
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── Платформа ───────────────────────────────────────────────────────────────
PLATFORM_NAME=МастерБот
PLATFORM_FEE_PCT=20.0
SENIOR_MASTER_SHARE_PCT=5.0
ADMIN_SHARE_PCT=5.0
DEFAULT_CURRENCY=RUB
DEFAULT_CITY=Стерлитамак
DEFAULT_REGION=Башкортостан

# ─── AI (опционально) ───────────────────────────────────────────────────────
AI_PROVIDER=disabled
AI_API_KEY=
AI_API_URL=
AI_MODEL=
AI_TIMEOUT_SEC=30

# ─── Оплата (реквизиты для клиентов) ────────────────────────────────────────
PAYMENT_PHONE=+79001234567
PAYMENT_BANK_NAME=Сбербанк
PAYMENT_RECIPIENT_NAME=ИП Иванов

# ─── Логирование ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── Администраторы ──────────────────────────────────────────────────────────
OWNER_TELEGRAM_ID=0
ADMIN_TELEGRAM_IDS=
